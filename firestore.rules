
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // تفعيل الوصول العام الكامل بدون الحاجة لتسجيل دخول رسمي عبر Firebase Auth
    // نعتمد على نظام إدارة الجلسات المحلي (رقم الهاتف) عبر Firestore فقط
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
