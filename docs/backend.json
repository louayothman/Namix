
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Namix platform.",
      "properties": {
        "id": { "type": "string" },
        "namixId": { "type": "string", "description": "Unique 10-digit identification number for internal transfers." },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "displayName": { "type": "string" },
        "gender": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "isVerified": { "type": "boolean" },
        "isBiometricEnabled": { "type": "boolean" },
        "fcmTokens": { "type": "array", "items": { "type": "string" }, "description": "List of device tokens for push notifications." },
        "notificationSettings": {
          "type": "object",
          "properties": {
            "priceAlerts": { "type": "boolean", "default": true },
            "accountAlerts": { "type": "boolean", "default": true }
          }
        },
        "totalBalance": { "type": "number" },
        "welcomeBonus": { "type": "number" },
        "activeInvestmentsTotal": { "type": "number" },
        "totalProfits": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "referralEarnings": { "type": "number" },
        "isAutoInvestEnabled": { "type": "boolean" },
        "autoInvestEnabledAt": { "type": "string", "format": "date-time" },
        "favoriteSymbols": { "type": "array", "items": { "type": "string" } },
        "lastActive": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "namixId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Stores user profiles and notification tokens."
        }
      }
    ]
  }
}
