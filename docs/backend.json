
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Namix platform.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "displayName": { "type": "string" },
        "gender": { "type": "string" },
        "password": { "type": "string" },
        "securityPin": { "type": "string", "description": "A 6-digit PIN required for financial transactions." },
        "totalBalance": { "type": "number" },
        "activeInvestmentsTotal": { "type": "number" },
        "totalProfits": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string", "description": "The UID of the user who referred this user." },
        "referralEarnings": { "type": "number" },
        "favoriteSymbols": { "type": "array", "items": { "type": "string" }, "description": "List of symbol IDs favorited by the user." },
        "tradingVolume": { "type": "number" },
        "isAutoInvestEnabled": { "type": "boolean" },
        "telegramChatId": { "type": "string", "description": "The unique Telegram Chat ID for notifications and bot interaction." },
        "telegramUsername": { "type": "string" },
        "tempLinkToken": { "type": "string", "description": "Temporary token for linking accounts." },
        "lastActive": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "MarketConnectivity": {
      "title": "MarketConnectivity",
      "type": "object",
      "description": "Configuration for external financial data providers.",
      "properties": {
        "binanceApiKey": { "type": "string" },
        "binanceApiSecret": { "type": "string" },
        "finnhubApiKey": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/system_settings/connectivity",
        "definition": {
          "entityName": "MarketConnectivity",
          "description": "Global API connectivity settings for Binance and Finnhub."
        }
      }
    ]
  }
}
