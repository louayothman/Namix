
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Namix platform.",
      "properties": {
        "id": { "type": "string" },
        "namixId": { "type": "string", "description": "Unique 10-digit identification number for internal transfers." },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "displayName": { "type": "string" },
        "gender": { "type": "string" },
        "password": { "type": "string" },
        "securityPin": { "type": "string" },
        "totalBalance": { "type": "number" },
        "activeInvestmentsTotal": { "type": "number" },
        "totalProfits": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "assignedWallets": { 
          "type": "object",
          "description": "Unique permanent addresses for deposits (e.g., { 'usdttrc20': 'TX...' })"
        },
        "nowPaymentsId": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "namixId"]
    },
    "MarketConnectivity": {
      "title": "MarketConnectivity",
      "type": "object",
      "description": "Configuration for external financial data providers.",
      "properties": {
        "binanceApiKey": { "type": "string" },
        "binanceApiSecret": { "type": "string" },
        "nowPaymentsApiKey": { "type": "string" },
        "nowPaymentsIpnSecret": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/system_settings/connectivity",
        "definition": {
          "entityName": "MarketConnectivity",
          "description": "Global API connectivity settings."
        }
      }
    ]
  }
}
